{
  "title": "bchat / App Performance",
  "uid": "bchat-app-performance",
  "schemaVersion": 39,
  "editable": true,
  "tags": ["bchat", "observability"],
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      { "name": "datasource", "type": "datasource", "query": "prometheus", "current": {} }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total request rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(bchat_http_requests_total[2m]))", "legendFormat": "total" }
      ]
    },
    {
      "id": 2,
      "title": "Request rate — top 10 routes",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "topk(10, sum by (route) (rate(bchat_http_requests_total[2m])))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Latency p50 / p95 / p99 (all routes, seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(bchat_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(bchat_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(bchat_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 4,
      "title": "5xx rate by route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (route) (rate(bchat_http_requests_total{status_code=~\"5..\"}[2m]))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "4xx rate by route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (route) (rate(bchat_http_requests_total{status_code=~\"4..\"}[2m]))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Active WebSocket connections",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(bchat_websocket_connections)", "legendFormat": "live sockets" }
      ]
    }
  ]
}

{
  "title": "bchat / LLM Performance",
  "uid": "bchat-llm-performance",
  "schemaVersion": 39,
  "editable": true,
  "tags": ["bchat", "observability"],
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      { "name": "datasource", "type": "datasource", "query": "prometheus", "current": {} }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Completions/min by model",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (model) (rate(bchat_chat_completions_total[2m])) * 60",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Completion latency p95 by model (total, seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, model) (rate(bchat_chat_completion_duration_seconds_bucket{phase=\"total\"}[5m])))",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Completion latency p50 / p95 / p99 (aggregated, seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(bchat_chat_completion_duration_seconds_bucket{phase=\"total\"}[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(bchat_chat_completion_duration_seconds_bucket{phase=\"total\"}[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(bchat_chat_completion_duration_seconds_bucket{phase=\"total\"}[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 4,
      "title": "Tokens/sec by model (LiteLLM)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (model) (rate(litellm_total_tokens[2m]))",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Estimated spend/hour by model (LiteLLM)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (model) (rate(litellm_spend_metric[5m])) * 3600",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Failure rate by provider (LiteLLM)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (api_provider) (rate(litellm_deployment_failure_responses[5m]))",
          "legendFormat": "{{api_provider}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Error rate — our metric",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (model) (rate(bchat_chat_completions_total{status=\"error\"}[5m]))",
          "legendFormat": "{{model}}"
        }
      ]
    }
  ]
}

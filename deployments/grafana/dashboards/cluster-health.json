{
  "title": "bchat / Cluster Health",
  "uid": "bchat-cluster-health",
  "schemaVersion": 39,
  "editable": true,
  "tags": ["bchat", "observability"],
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "CPU per pod (cores)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"default\", pod=~\"app-.*|litellm-.*|mcp-.*\"}[2m]))",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Memory per pod (MiB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"default\", pod=~\"app-.*|litellm-.*|mcp-.*\"}) / 1024 / 1024",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Pod restarts (24h)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (pod) (increase(kube_pod_container_status_restarts_total{namespace=\"default\"}[24h]))",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "HPA: current vs. desired replicas",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=\"default\"}",
          "legendFormat": "current — {{horizontalpodautoscaler}}"
        },
        {
          "expr": "kube_horizontalpodautoscaler_status_desired_replicas{namespace=\"default\"}",
          "legendFormat": "desired — {{horizontalpodautoscaler}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Node CPU utilisation (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "100 * (1 - avg by (node) (rate(node_cpu_seconds_total{mode=\"idle\"}[2m])))",
          "legendFormat": "{{node}}"
        }
      ]
    }
  ]
}

{
  "displayName": "bchat / LLM Performance",
  "dashboardFilters": [
    {
      "labelKey": "namespace",
      "templateVariable": "namespace",
      "stringValue": "prod",
      "filterType": "RESOURCE_LABEL"
    }
  ],
  "mosaicLayout": {
    "columns": 12,
    "tiles": [
      {
        "xPos": 0,
        "yPos": 0,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Completions per hour by model",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "sum by (model) (increase(bchat_chat_completions_total{${namespace}}[1h]))"
                },
                "plotType": "LINE"
              }
            ]
          }
        }
      },
      {
        "xPos": 6,
        "yPos": 0,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Completion latency p95 by model (total, seconds)",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "histogram_quantile(0.95, sum by (le, model) (rate(bchat_chat_completion_duration_seconds_bucket{${namespace}, phase=\"total\"}[1h])))"
                },
                "plotType": "LINE"
              }
            ]
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 4,
        "width": 12,
        "height": 4,
        "widget": {
          "title": "Completion latency p50 / p95 / p99 (aggregated, seconds)",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "histogram_quantile(0.50, sum by (le) (rate(bchat_chat_completion_duration_seconds_bucket{${namespace}, phase=\"total\"}[1h])))"
                },
                "plotType": "LINE"
              },
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "histogram_quantile(0.95, sum by (le) (rate(bchat_chat_completion_duration_seconds_bucket{${namespace}, phase=\"total\"}[1h])))"
                },
                "plotType": "LINE"
              },
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "histogram_quantile(0.99, sum by (le) (rate(bchat_chat_completion_duration_seconds_bucket{${namespace}, phase=\"total\"}[1h])))"
                },
                "plotType": "LINE"
              }
            ]
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 8,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Tokens per hour by model (LiteLLM)",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "sum by (model) (increase(litellm_total_tokens_metric_total{${namespace}}[1h]))"
                },
                "plotType": "LINE"
              }
            ]
          }
        }
      },
      {
        "xPos": 6,
        "yPos": 8,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Estimated spend per hour by model (LiteLLM)",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "sum by (model) (increase(litellm_spend_metric_total{${namespace}}[1h]))"
                },
                "plotType": "LINE"
              }
            ]
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 12,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Failures per hour by provider (LiteLLM)",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "sum by (api_provider) (increase(litellm_deployment_failure_responses_total{${namespace}}[1h]))"
                },
                "plotType": "STACKED_AREA"
              }
            ]
          }
        }
      },
      {
        "xPos": 6,
        "yPos": 12,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Errors per hour by model (bchat)",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "sum by (model) (increase(bchat_chat_completions_total{${namespace}, status=\"error\"}[1h]))"
                },
                "plotType": "STACKED_AREA"
              }
            ]
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 16,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Avg input tokens per completion by model (LiteLLM)",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "sum by (model) (rate(litellm_input_tokens_metric_total{${namespace}}[1h])) / sum by (model) (rate(litellm_requests_metric_total{${namespace}}[1h]))"
                },
                "plotType": "LINE"
              }
            ]
          }
        }
      },
      {
        "xPos": 6,
        "yPos": 16,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Avg output tokens per completion by model (LiteLLM)",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "sum by (model) (rate(litellm_output_tokens_metric_total{${namespace}}[1h])) / sum by (model) (rate(litellm_requests_metric_total{${namespace}}[1h]))"
                },
                "plotType": "LINE"
              }
            ]
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 20,
        "width": 4,
        "height": 4,
        "widget": {
          "title": "Avg input tokens / completion (last 30d)",
          "scorecard": {
            "timeSeriesQuery": {
              "prometheusQuery": "round(sum(rate(litellm_input_tokens_metric_total{${namespace}}[30d])) / sum(rate(litellm_requests_metric_total{${namespace}}[30d])))"
            }
          }
        }
      },
      {
        "xPos": 4,
        "yPos": 20,
        "width": 4,
        "height": 4,
        "widget": {
          "title": "Avg output tokens / completion (last 30d)",
          "scorecard": {
            "timeSeriesQuery": {
              "prometheusQuery": "round(sum(rate(litellm_output_tokens_metric_total{${namespace}}[30d])) / sum(rate(litellm_requests_metric_total{${namespace}}[30d])))"
            }
          }
        }
      },
      {
        "xPos": 8,
        "yPos": 20,
        "width": 4,
        "height": 4,
        "widget": {
          "title": "Avg total tokens / completion (last 30d)",
          "scorecard": {
            "timeSeriesQuery": {
              "prometheusQuery": "round(sum(rate(litellm_total_tokens_metric_total{${namespace}}[30d])) / sum(rate(litellm_requests_metric_total{${namespace}}[30d])))"
            }
          }
        }
      }
    ]
  }
}
